# ============================================================
# SOC-Mini Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# MISP (Malware Information Sharing Platform)
MISP_URL=https://localhost:8443
MISP_API_KEY=your_misp_api_key_here

# VirusTotal API
VT_API_KEY=your_virustotal_api_key_here

# Shuffle SOAR
SHUFFLE_WEBHOOK_URL=https://shuffler.io/api/v1/hooks/webhook_your_hook_id_here
SHUFFLE_API_KEY=your_shuffle_api_key_here
SHUFFLE_WORKFLOW_ID=your_shuffle_workflow_id_here
